# Database Configuration
DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simple_blog_db
DB_USER=postgres
DB_PASSWORD=root

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Session Configuration
SESSION_LIFETIME=3600

# Email Configuration (Mailtrap API)
MAILTRAP_API_KEY=
MAILTRAP_USE_SANDBOX=true
MAILTRAP_INBOX_ID=
MAIL_FROM=noreply@simpleblog.com
MAIL_FROM_NAME="Simple Blog System"

# Upload Configuration
MAX_UPLOAD_SIZE=5242880
UPLOAD_PATH=storage/uploads/images/

# API Configuration (for future API development)
API_TOKEN_EXPIRY=86400
